# Copy to .env.development.local for local development (gitignored, never committed).
# These let the app auto-load your keys locally so you skip the Settings panel.
# The public GitHub Pages build does NOT include these — enter keys in the
# in-app Settings panel there instead, so your keys never ship in a public bundle.
VITE_ORS_KEY=your-openrouteservice-key
VITE_OCM_KEY=your-open-charge-map-key
